{
  "name": "@hangup/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack -p 3000",
    "build": "next build --webpack",
    "start": "next start -p 3000",
    "lint": "eslint",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf:build": "opennextjs-cloudflare build",
    "docker:build:ct": "docker build -f Dockerfile.ct -t myapp-playwright-ct-tests ../..",
    "test:ct:show-report": "pnpm exec playwright show-report --port 9323",
    "test:ct": "pnpm run docker:build:ct && mkdir -p playwright-report && docker run --rm -v $(pwd)/playwright-report:/app/apps/web/playwright-report -v $(pwd)/__snapshots__:/app/apps/web/__snapshots__ myapp-playwright-ct-tests pnpm playwright test -c playwright-ct.config.ts",
    "test:ct:update-snapshots": "pnpm run docker:build:ct && docker run --rm -v $(pwd)/__snapshots__:/app/apps/web/__snapshots__ myapp-playwright-ct-tests pnpm playwright test -c playwright-ct.config.ts --update-snapshots",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@date-fns/tz": "^1.5.0",
    "@next/third-parties": "^16.2.9",
    "@hangup/shared": "workspace:*",
    "@radix-ui/react-accordion": "^1.2.13",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "daisyui": "^5.5.23",
    "date-fns": "^4.4.0",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.18.0",
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.79.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "tailwindcss-animate": "^1.0.7",
    "vanilla-cookieconsent": "^3.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.3.0",
    "@playwright/experimental-ct-react": "^1.61.0",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "^4.3.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.15",
    "wrangler": "^4.20.0"
  }
}
