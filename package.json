{
  "name": "animation-next-js",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test:unit": "vitest run",
    "docker:build:ct": "docker build . -f Dockerfile.ct -t myapp-playwright-ct-tests",
    "test:ct:show-report": "pnpm exec playwright show-report --port 9323",
    "test:ct": "pnpm run docker:build:ct && mkdir -p playwright-report && docker run --rm -v $(pwd)/playwright-report:/app/playwright-report -v $(pwd)/__snapshots__:/app/__snapshots__ myapp-playwright-ct-tests pnpm playwright test -c playwright-ct.config.ts",
    "test:ct:update-snapshots": "pnpm run docker:build:ct && docker run --rm -v $(pwd)/__snapshots__:/app/__snapshots__ myapp-playwright-ct-tests pnpm playwright test -c playwright-ct.config.ts --update-snapshots"
  },
  "dependencies": {
    "@date-fns/tz": "^1.5.0",
    "@google-apps/meet": "^0.7.2",
    "@google-cloud/firestore": "^8.6.0",
    "@google-cloud/local-auth": "^3.0.1",
    "@google-cloud/tasks": "^6.2.3",
    "@next/third-parties": "^16.2.9",
    "@radix-ui/react-accordion": "^1.2.13",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "daisyui": "^5.5.23",
    "date-fns": "^4.4.0",
    "framer-motion": "^12.40.0",
    "googleapis": "^173.0.0",
    "lucide-react": "^1.18.0",
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.79.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "tailwindcss-animate": "^1.0.7",
    "vanilla-cookieconsent": "^3.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/css": "^1.3.0",
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^2.0.0",
    "@next/eslint-plugin-next": "^16.2.9",
    "@playwright/experimental-ct-react": "^1.61.0",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "^4.3.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.15",
    "prettier": "3.8.4",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.9"
  }
}
